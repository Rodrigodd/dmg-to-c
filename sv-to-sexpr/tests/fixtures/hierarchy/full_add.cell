(cell
  dmg_full_add
  (inputs a b cin)

  (outputs sum cout)

  (registers)

  (assignments

    (sum
      (xor axb cin)
      (delay
        (+ (elmore (wire 122) (nmos 35)) (elmore (wire L_sum) (* (pmos 35) 2)))
        (+ (elmore (wire 122) (* (pmos 35) 2)) (elmore (wire L_sum) (* (nmos 35) 2)))
      )
    )
    (caxb (nand cin axb) (delay (elmore (wire 120) (pmos 35)) (elmore (wire 120) (* (nmos 35) 2))))
    (cout
      (nand ab caxb)
      (delay (elmore (wire L_cout) (pmos 35)) (elmore (wire L_cout) (* (nmos 35) 2)))
    )
    (ab (nand b a) (delay (elmore (wire 119) (pmos 35)) (elmore (wire 119) (* (nmos 35) 2))))
    (axb
      (xor a b)
      (delay
        (+ (elmore (wire 122) (nmos 35)) (elmore (wire 296) (* (pmos 35) 2)))
        (+ (elmore (wire 122) (* (pmos 35) 2)) (elmore (wire 296) (* (nmos 35) 2)))
      )
    )
  )
)
