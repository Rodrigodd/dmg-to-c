(cell
  dmg_pad_xtal
  (inputs ena in_pad)

  (outputs clk_n out_pad)

  (registers)

  (assignments

    (ena_n (not ena) (delay (elmore (wire 130) (pmos 7)) (elmore (wire 130) (nmos 7))))
    (clk
      (bufif0-strength
        1
        ena
        strong1
        highz0
      )
      (delay (elmore (wire 130) (pmos 7)) (elmore (wire 130) (nmos 28)))
    )
    (clk
      (bufif0-strength
        in_pad
        ena_n
        strong1
        highz0
      )
      (delay (elmore (wire 130) (pmos 33)) (elmore (wire 130) (nmos 28)))
    )
    (clk
      (bufif1-strength
        in_pad
        ena
        highz1
        strong0
      )
      (delay (elmore (wire 130) (pmos 33)) (elmore (wire 130) (nmos 28)))
    )
    (clk (keeper) (delay 0))
    (out_pad
      (not clk)
      (delay (elmore (wire L_out_pad) (pmos 62)) (elmore (wire L_out_pad) (nmos 25)))
    )
    (clk_n
      (not clk)
      (delay (elmore (wire L_clk_n) (pmos 13.5)) (elmore (wire L_clk_n) (nmos 10.8)))
    )
  )
)
