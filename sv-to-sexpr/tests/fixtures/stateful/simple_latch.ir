source: sv-cells/dmg_cpu_b/cells/dlatch.sv
cell: dmg_dlatch
inputs: [d, ena]
outputs: [q, q_n]
registers: [q=0]
assignments:
  0: q
    value: op(mux; atom(ena), atom(d), atom(q))
    delay: op(+; op(+; op(elmore; op(wire; atom(73)), op(pmos; atom(10))), op(elmore; op(wire; atom(101)), op(nmos; atom(10)))), op(elmore; op(wire; atom(L_q)), op(pmos; atom(35))))
  1: q_n
    value: op(not; atom(q))
    delay: op(+; op(+; op(+; op(elmore; op(wire; atom(73)), op(nmos; atom(10))), op(elmore; op(wire; atom(101)), op(pmos; atom(10)))), op(elmore; op(wire; atom(127)), op(nmos; atom(10)))), op(elmore; op(wire; atom(L_q_n)), op(pmos; atom(35))))
