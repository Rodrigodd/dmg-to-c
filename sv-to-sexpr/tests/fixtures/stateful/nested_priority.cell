(cell
  nested_priority
  (inputs
    enable
    reset_n
    set
    t0
  )

  (outputs q)

  (registers (q 0))

  (assignments

    (t1 (not reset_n) (delay 0))
    (t2 (and enable t1) (delay 0))
    (q (mux t2 0 q) (delay 0))
    (t3 (and set t0) (delay 0))
    (t4 (and enable t3) (delay 0))
    (q (mux t4 1 q) (delay 0))
  )
)
