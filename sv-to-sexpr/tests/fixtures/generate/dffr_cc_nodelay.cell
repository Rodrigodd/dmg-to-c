(cell
  dmg_dffr_cc
  (inputs
    d
    clk
    clk_n
    r_n
  )

  (outputs q q_n)

  (registers (ff 0) (q 0))

  (assignments

    (clk_buf clk (delay 0))
    (clk_n_buf clk_n (delay 0))
    (r_n_buf r_n (delay 0))
    (t0 (not clk_buf) (delay 0))
    (t1 (and d t0) (delay 0))
    (t2 (not d) (delay 0))
    (t3 (and t2 clk_n_buf) (delay 0))
    (t4 (not r_n_buf) (delay 0))
    (t5 (or t1 t3 t4) (delay 0))
    (t6 (and d r_n_buf) (delay 0))
    (ff (mux t5 t6 ff) (delay 0))
    (t7 (not clk_n_buf) (delay 0))
    (t8 (and ff t7) (delay 0))
    (t9 (not ff) (delay 0))
    (t10 (and t9 clk_buf) (delay 0))
    (t11 (not r_n_buf) (delay 0))
    (t12 (or t8 t10 t11) (delay 0))
    (t13 (and ff r_n_buf) (delay 0))
    (q (mux t12 t13 q) (delay 0))
    (q_n (not q) (delay 0))
  )
)
