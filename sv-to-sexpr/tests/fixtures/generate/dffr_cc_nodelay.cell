(cell
  dmg_dffr_cc
  (inputs
    d
    clk
    clk_n
    r_n
  )

  (outputs q q_n)

  (registers ff q)

  (assignments

    (clk_buf clk 0)
    (clk_n_buf clk_n 0)
    (r_n_buf r_n 0)
    (t0 (not clk_buf) 0)
    (t1 (and d t0) 0)
    (t2 (not d) 0)
    (t3 (and t2 clk_n_buf) 0)
    (t4 (not r_n_buf) 0)
    (t5 (or t1 t3 t4) 0)
    (t6 (and d r_n_buf) 0)
    (ff (mux t5 t6 ff) 0)
    (t7 (not clk_n_buf) 0)
    (t8 (and ff t7) 0)
    (t9 (not ff) 0)
    (t10 (and t9 clk_buf) 0)
    (t11 (not r_n_buf) 0)
    (t12 (or t8 t10 t11) 0)
    (t13 (and ff r_n_buf) 0)
    (q (mux t12 t13 q) 0)
    (q_n (not q) 0)
  )
)
