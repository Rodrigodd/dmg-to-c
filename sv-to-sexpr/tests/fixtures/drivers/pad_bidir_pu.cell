(cell
  dmg_pad_bidir_pu
  (inputs
    ndrv
    pdrv_n
    ena_n_pu
    pad
  )

  (outputs i_n pad)

  (registers )

  (assignments

    (pad
      (bufif1-strength 0 ndrv highz1 strong0)
      (elmore (wire L_pad) (pmos 140))
    )
    (pad
      (bufif0-strength 1 pdrv_n strong1 highz0)
      (elmore (wire L_pad) (pmos 140))
    )
    (pad
      (bufif0-strength 1 ena_n_pu pull1 highz0)
      (* (elmore (wire L_pad) (pmos 140)) 10)
    )
    (i_n (not pad) (elmore (wire L_i_n) (pmos 15)))
  )
)
