(cell
  dmg_ao21
  (inputs in1 in2 in3)

  (outputs y)

  (registers)

  (assignments

    (t0 (and in1 in2) (delay 0))
    (y
      (or t0 in3)
      (delay
        (+ (elmore (wire 112) (* (nmos 35) 2)) (elmore (wire L_y) (pmos 35)))
        (+ (elmore (wire 112) (* (pmos 35) 2)) (elmore (wire L_y) (nmos 35)))
      )
    )
  )
)
