(cell
  dmg_and3
  (inputs in1 in2 in3)

  (outputs y)

  (registers)

  (assignments

    (y
      (and in1 in2 in3)
      (delay
        (+ (elmore (wire 135) (* (nmos 35) 3)) (elmore (wire L_y) (pmos 35)))
        (+ (elmore (wire 135) (pmos 35)) (elmore (wire L_y) (nmos 35)))
      )
    )
  )
)
