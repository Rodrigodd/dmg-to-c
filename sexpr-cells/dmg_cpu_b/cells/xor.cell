(cell
  dmg_xor
  (inputs in1 in2)

  (outputs y)

  (registers)

  (assignments

    (y
      (xor in1 in2)
      (delay
        (+ (elmore (wire 122) (nmos 35)) (elmore (wire L_y) (* (pmos 35) 2)))
        (+ (elmore (wire 122) (* (pmos 35) 2)) (elmore (wire L_y) (* (nmos 35) 2)))
      )
    )
  )
)
