(cell
  dmg_pad_out_diff
  (inputs ndrv pdrv_n)

  (outputs pad)

  (registers)

  (assignments

    (pad
      (bufif1-strength
        0
        ndrv
        highz1
        strong0
      )
      (delay (elmore (wire L_pad) (pmos 140)) (elmore (wire L_pad) (nmos 140)))
    )
    (pad
      (bufif0-strength
        1
        pdrv_n
        strong1
        highz0
      )
      (delay (elmore (wire L_pad) (pmos 140)) (elmore (wire L_pad) (nmos 140)))
    )
  )
)
