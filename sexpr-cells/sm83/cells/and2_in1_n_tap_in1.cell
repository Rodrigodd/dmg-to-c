(cell
  sm83_and2_in1_n_tap_in1
  (inputs in1_n in2)

  (outputs y tap_in1)

  (registers)

  (assignments

    (tap_in1 (not in1_n) (elmore (wire L_tap_in1) (pmos 3)))
    (y
      (and tap_in1 in2)
      (+
        (+ (elmore (wire L_tap_in1) (pmos 3)) (elmore (wire 40) (* (nmos 3) 2)))
        (elmore (wire L_y) (pmos 3))
      )
    )
  )
)
