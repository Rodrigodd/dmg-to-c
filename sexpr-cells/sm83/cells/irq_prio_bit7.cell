      (+ (elmore (wire 24) (* (nmos 3.0) 2)) (elmore (wire L_and_a_y) (pmos 14.5)))
    )
    (nand_b_in2_n (not nand_b_in2) (elmore (wire 72) (pmos 3)))
    (and_b_y
