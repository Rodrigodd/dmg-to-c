      (+ (elmore (wire 33) (* (nmos 3) 2)) (elmore (wire L_and_b_y) (pmos 6)))
    )
    (t0 (and pch_n and_a_in2_nand_a_in2) 0)
    (nand_a_y
      (bufif1-strength
        0
        t0
        highz1
        strong0
      )
      (elmore (wire L_nand_a_y) (* (nmos 6) 2))
    )
    (t1
      (and
        pch_n
        nand_b_in2
        nand_b_in3
        nand_b_in4
        nand_b_in5
        nand_b_in6
        nand_b_in7
        nand_b_in8
        nand_b_in9
      )
      0
    )
    (nand_b_y
      (bufif1-strength
        0
        t1
        highz1
        strong0
      )
      (elmore (wire L_nand_b_y) (* (nmos 6) 9))
    )
    (t2 (and pch_n and_a_y) 0)
    (nand_c_y
      (bufif1-strength
        0
        t2
        highz1
        strong0
      )
      (elmore (wire L_nand_c_y) (* (nmos 6) 2))
    )
    (t3 (and pch_n and_a_y) 0)
    (nand_d_y
      (bufif1-strength
        0
        t3
        highz1
        strong0
      )
      (elmore (wire L_nand_d_y) (* (nmos 6) 2))
    )
    (t4 (and pch_n and_a_y) 0)
    (nand_e_y
      (bufif1-strength
        0
        t4
        highz1
        strong0
      )
      (elmore (wire L_nand_e_y) (* (nmos 6) 2))
    )
    (dist_nand_a_y_p
      (bufif0-strength
        1
        dist_nand_a_in
        strong1
        highz0
      )
      (elmore (wire L_dist_nand_a_y_p) (pmos 3))
    )
    (dist_nand_a_y_n
      (bufif1-strength
        0
        dist_nand_a_in
        highz1
        strong0
      )
      (elmore (wire L_dist_nand_a_y_n) (nmos 3))
    )
    (dist_nand_b_y_p
      (bufif0-strength
        1
        dist_nand_b_in
        strong1
        highz0
      )
      (elmore (wire L_dist_nand_b_y_p) (pmos 3))
    )
    (dist_nand_b_y_n
      (bufif1-strength
        0
        dist_nand_b_in
        highz1
        strong0
      )
      (elmore (wire L_dist_nand_b_y_n) (nmos 3))
    )
    (t5 (or nand_b_in2_n dist_nor_in2) 0)
    (dist_nor_y_p
      (bufif0-strength
        1
        t5
        strong1
        highz0
      )
      (elmore (wire L_dist_nor_y_p) (+ (pmos 5) (pmos 6)))
    )
    (t6 (or nand_b_in2_n dist_nor_in2) 0)
    (dist_nor_y_n
      (bufif1-strength
        0
        t6
        highz1
        strong0
      )
      (elmore (wire L_dist_nor_y_n) (nmos 3))
