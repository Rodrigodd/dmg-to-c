    nand_b_in2
    nand_b_in3
    nand_b_in4
    nand_b_in5
    nand_b_in6
    nand_b_in7
    nand_b_in8
    nand_b_in9
    dist_nand_a_in
    dist_nand_b_in
    dist_nor_in2
  )

  (outputs
