(cell
  sm83_xor_idu_h
  (inputs in1 in2)

  (outputs y)

  (registers)

  (assignments

    (y
      (xor in1 in2)
      (delay
        (+
          (+ (elmore (wire 26) (pmos 3)) (elmore (wire 29) (* (nmos 5) 2)))
          (elmore (wire L_y) (pmos 13))
        )
        (+
          (+ (elmore (wire 26) (* (nmos 3) 2)) (elmore (wire 29) (* (pmos 5) 2)))
          (elmore (wire L_y) (nmos 8))
        )
      )
    )
  )
)
