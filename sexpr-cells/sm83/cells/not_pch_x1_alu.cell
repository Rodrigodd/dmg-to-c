(cell
  sm83_not_pch_x1_alu
  (inputs pch_n in)

  (outputs y in)

  (registers)

  (assignments

    (y (not in) (delay (elmore (wire L_y) (pmos 15)) (elmore (wire L_y) (nmos 5))))
    (in
      (bufif0-strength
        1
        pch_n
        strong1
        highz0
      )
      (delay
        (elmore (wire L_in) (pmos 3))
        (elmore (wire L_in) (pmos 3))
        (elmore (wire L_in) (pmos 3))
      )
    )
  )
)
