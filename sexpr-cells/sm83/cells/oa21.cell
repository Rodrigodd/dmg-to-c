(cell
  sm83_oa21
  (inputs in1 in2 in3)

  (outputs y)

  (registers)

  (assignments

    (t0 (or in1 in2) (delay 0))
    (y
      (and t0 in3)
      (delay
        (+ (elmore (wire 25) (* (nmos 3) 2)) (elmore (wire L_y) (pmos 30)))
        (+ (elmore (wire 25) (* (pmos 3) 2)) (elmore (wire L_y) (nmos 15)))
      )
    )
  )
)
