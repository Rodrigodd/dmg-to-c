(cell
  sm83_or2_tap_nor_tap_in1_n_reg
  (inputs in1 in2)

  (outputs y tap_nor tap_in1_n)

  (registers)

  (assignments

    (tap_nor (nor in1 in2) (elmore (wire L_tap_nor) (* (pmos 8) 2)))
    (tap_in1_n (not in1) (elmore (wire L_tap_in1_n) (pmos 12)))
    (y (not tap_nor) (+ (elmore (wire L_tap_nor) (nmos 9)) (elmore (wire L_y) (pmos 12))))
  )
)
