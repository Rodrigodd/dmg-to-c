(cell
  sm83_srlatch_r_n
  (inputs s r_n)

  (outputs q)

  (registers (q x))

  (assignments

    (t0 (not r_n) (delay 0))
    (t1 (or t0 s) (delay 0))
    (t2 (and s r_n) (delay 0))
    (q
      (mux t1 t2 q)
      (delay
        (+ (elmore (wire 51) (* (nmos 16.5) 2)) (elmore (wire L_q) (pmos 11.0)))
        (+ (elmore (wire 51) (pmos 16.5)) (elmore (wire L_q) (nmos 5.0)))
      )
    )
  )
)
