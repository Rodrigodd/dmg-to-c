(cell
  sm83_mux_idu_h
  (inputs d0 d1 sel)

  (outputs y)

  (registers)

  (assignments

    (y
      (mux sel d1 d0)
      (delay
        (+ (elmore (wire 28) (* (nmos 3) 2)) (elmore (wire L_y) (pmos 13)))
        (+ (elmore (wire 28) (* (pmos 3) 2)) (elmore (wire L_y) (nmos 5)))
      )
    )
  )
)
