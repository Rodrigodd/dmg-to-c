        t1
        highz1
        strong0
      )
      (delay
        (elmore (wire L_a) (pmos 27))
        (elmore (wire L_a) (* (nmos 24) 2))
        (elmore (wire L_a) (pmos 27))
      )
    )
    (or_pch
      (or pch_n oe_n)
      (delay
        (+ (elmore (wire 24) (nmos 5)) (elmore (wire 36) (pmos 5)))
        (+ (elmore (wire 24) (* (pmos 5) 2)) (elmore (wire 36) (nmos 12)))
      )
    )
    (nor_ab (nor oe_n a) (delay (elmore (wire 55) (* (pmos 14) 2)) (elmore (wire 55) (nmos 5))))
    (b
      (bufif0-strength
        1
        or_pch
        strong1
        highz0
      )
      (delay
        (elmore (wire L_b) (pmos 50))
        (elmore (wire L_b) (nmos 84))
        (elmore (wire L_b) (pmos 50))
