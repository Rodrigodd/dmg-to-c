  )

  (outputs a b)

  (registers)

  (assignments

    (inj_d_n (not inj_d) (delay (elmore (wire 17) (pmos 5)) (elmore (wire 17) (nmos 5))))
    (nor_pp (nor b oe_n) (delay (elmore (wire 16) (* (pmos 9) 2)) (elmore (wire 16) (nmos 5))))
    (a
      (bufif0-strength
        1
        pch_n
        strong1
        highz0
      )
      (delay
        (elmore (wire L_a) (pmos 27))
        (elmore (wire L_a) (* (nmos 29) 2))
        (elmore (wire L_a) (pmos 27))
      )
    )
    (t0 (and pch_n nor_pp) (delay 0))
    (a
      (bufif1-strength
        0
        t0
        highz1
        strong0
      )
      (delay
        (elmore (wire L_a) (pmos 27))
        (elmore (wire L_a) (* (nmos 29) 2))
        (elmore (wire L_a) (pmos 27))
      )
    )
    (t1 (and inj_en inj_d_n) (delay 0))
    (a
      (bufif1-strength
