(cell
  sm83_nand2_in1_n_c
  (inputs in1_n in2)

  (outputs y)

  (registers)

  (assignments

    (t0 (not in1_n) (delay 0))
    (y
      (nand t0 in2)
      (delay
        (+ (elmore (wire 17) (nmos 3)) (elmore (wire L_y) (pmos 3)))
        (+ (elmore (wire 17) (pmos 3)) (elmore (wire L_y) (* (nmos 3) 2)))
      )
    )
  )
)
