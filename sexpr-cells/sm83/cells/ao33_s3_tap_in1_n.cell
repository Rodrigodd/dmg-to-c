(cell
  sm83_ao33_s3_tap_in1_n
  (inputs
    in1
    in2
    in3
    in4
    in5
  )

  (outputs y tap_in1_n)

  (registers)

  (assignments

    (t0 (and in1 in2 in3) 0)
    (t1 (and in4 in5 in3) 0)
    (y (or t0 t1) (+ (elmore (wire 14) (* (nmos 3) 3)) (elmore (wire L_y) (pmos 3))))
    (tap_in1_n (not in1) (elmore (wire L_tap_in1_n) (pmos 4)))
  )
)
