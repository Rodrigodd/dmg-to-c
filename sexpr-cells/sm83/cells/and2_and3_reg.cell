(cell
  sm83_and2_and3_reg
  (inputs
    a_in1
    a_in2
    b_in1
    b_in2
    b_in3
  )

  (outputs a_y b_y)

  (registers)

  (assignments

    (a_y (and a_in1 a_in2) (+ (elmore (wire 29) (* (nmos 3) 2)) (elmore (wire L_a_y) (pmos 8))))
    (b_y
      (and b_in1 b_in2 b_in3)
      (+ (elmore (wire 35) (* (nmos 3) 3)) (elmore (wire L_b_y) (pmos 10)))
    )
  )
)
